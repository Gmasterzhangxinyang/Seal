# DashScope API Key（阿里云百炼，用于语音识别）
DASHSCOPE_API_KEY=sk-...

# OpenAI API Key（Whisper ASR 用）
OPENAI_API_KEY=sk-...

# 数据库（MySQL）
DB_HOST=localhost
DB_PORT=3306
DB_USER=stamp_robot
DB_PASSWORD=your_db_password
DB_NAME=stamp_robot

SECRET_KEY=your_secret_key

# 视觉大模型（OCR）— 智谱 GLM
ZHIPU_API_KEY=...
VLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
VLM_MODEL=glm-4.6v
CHAT_MODEL=glm-4-flash

# Fish Audio TTS
FISH_AUDIO_API_KEY=...

# 文档管理系统（DMS）集成（留空则跳过）
DMS_BASE_URL=
DMS_API_KEY=

AURORA_CHAT_URL=""
MEC202_WEBHOOK_URL=""

# Dify 工作流
DIFY_API_KEY=
DIFY_VOICE_CHAT_APP_ID=
DIFY_VOICE_TTS_APP_ID=
